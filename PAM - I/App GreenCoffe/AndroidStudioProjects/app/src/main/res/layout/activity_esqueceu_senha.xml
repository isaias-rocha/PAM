<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@color/white">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- LOGO -->
    <ImageView
        android:id="@+id/img_Logo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/logo_colorido"
        android:scaleType="fitCenter"
        android:contentDescription="Logo"/>

    <!-- TITULO -->
    <TextView android:id="@+id/txt_Titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recuperar Senha"
        android:textColor="@color/Marrom_Cafe"
        android:textStyle="bold"
        android:textSize="30sp"
        android:layout_marginTop="20dp"/>

    <!-- DESCRICAO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Digite seu e-mail para receber o link de recuperação"
        android:textColor="#BDBDBD"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="35dp"/>

    <!-- EMAIL -->
    <EditText
        android:id="@+id/edt_EmailRecuperacao"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Digite seu e-mail"
        android:textColor="@color/black"
        android:textColorHint="#9E9E9E"
        android:backgroundTint="#007A4D"
        android:inputType="textEmailAddress"
        android:padding="12dp"
        android:layout_marginBottom="30dp"/>

    <!-- BOTAO -->
    <Button
        android:id="@+id/btn_Enviar"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="ENVIAR LINK"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="@color/Verde_Escuro"/>

    <!-- VOLTAR -->
    <TextView
        android:id="@+id/txt_VoltarLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voltar para Login"
        android:textColor="#00C853"
        android:textSize="14sp"
        android:layout_marginTop="25dp"/>

</LinearLayout>

</ScrollView>